<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <title>Login - Admin FCE</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    body {
      margin: 0;
      padding: 0;
      min-height: 100vh;
      background: linear-gradient(135deg, #003366 0%, #001a33 100%);                  
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .login-container {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .escudo-logo {
      width: 200px;
      height: auto;
      filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.3));
      margin: 0 auto;
    }

    @media (max-width: 576px) {
      .escudo-logo {
        width: 60px;
      }
    }

    .glass-form {
      background: rgba(255, 255, 255, 0.15);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 20px;
      padding: 2.5rem;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
      width: 100%;
      max-width: 400px;
    }

    .glass-form .form-control {
      background: rgba(255, 255, 255, 0.2);
      border: 1px solid rgba(255, 255, 255, 0.3);
      color: white;
      padding: 0.75rem 1rem;
    }

    .glass-form .form-control::placeholder {
      color: rgba(255, 255, 255, 0.7);
    }

    .glass-form .form-control:focus {
      background: rgba(255, 255, 255, 0.25);
      border-color: rgba(255, 255, 255, 0.5);
      box-shadow: 0 0 0 0.25rem rgba(255, 255, 255, 0.25);
      color: white;
    }

    .glass-form .btn-primary {
      background: rgba(13, 110, 253, 0.8);
      border: none;
      padding: 0.75rem;
      font-weight: 600;
      transition: all 0.3s ease;
    }

    .glass-form .btn-primary:hover {
      background: rgba(13, 110, 253, 1);
      transform: translateY(-2px);
      box-shadow: 0 4px 20px rgba(13, 110, 253, 0.4);
    }

    .glass-form h2 {
      color: white;
      font-size: 1.5rem;
      margin-bottom: 1rem;
      text-align: center;
      font-weight: 600;
      text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
    }

    .glass-form label {
      color: rgba(255, 255, 255, 0.9);
      font-weight: 500;
      margin-bottom: 0.5rem;
    }

    /* ESTILO MEJORADO PARA ERROR - MUCHO MÁS NOTORIO */
    .error-message {
      background: #dc3545;
      color: white;
      padding: 1rem;
      border-radius: 10px;
      margin-bottom: 1.5rem;
      text-align: center;
      font-weight: 600;
      font-size: 1rem;
      border-left: 5px solid #ffc107;
      box-shadow: 0 4px 15px rgba(220, 53, 69, 0.5);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }

    .error-message i {
      font-size: 1.5rem;
      color: #ffc107;
    }

    /* Para cuando no hay error, el contenedor no ocupa espacio */
    .error-message:empty {
      display: none;
    }
  </style>
</head>
<body>
  <div class="login-container">
    <div class="glass-form">
      <div class="text-center mb-4">
        <img src="/img/index/logo_fce.png" alt="Escudo FCE UNMSM" class="escudo-logo">
        <h2 class="mt-3">Panel de Administración Web - FCE</h2>
      </div>

      <!-- MOSTRAR ERROR SOLO SI EXISTE -->
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="error-message">
          <i class="fas fa-exclamation-triangle"></i>
          <%= error %>
        </div>
      <% } %>

      <form action="/admin/login" method="post">
        <div class="mb-3">
          <label>Usuario</label>
          <input type="text" name="username" class="form-control" 
                 value="<%= typeof username !== 'undefined' ? username : '' %>" 
                 placeholder="Ingrese su usuario" required>
        </div>
        <div class="mb-3">
          <label>Contraseña</label>
          <input type="password" name="password" class="form-control" 
                 placeholder="Ingrese su contraseña" required>
        </div>
        <button type="submit" class="btn btn-primary w-100">
          <i class="fas fa-sign-in-alt me-2"></i>Entrar
        </button>
      </form>
    </div>
  </div>
</body>
</html>